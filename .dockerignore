# Dependencies (will be installed in container)
node_modules/
frontend/node_modules/
**/node_modules/

# Build output (will be built in container)
dist/
frontend/dist/
**/dist/

# Data directories (mounted as volume)
data/
*.db
*.db-journal

# Git
.git/
.gitignore
.gitattributes

# IDE and editor configs
.vscode/
.idea/
*.swp
*.swo
*~

# Kiro specs
.kiro/

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files
.env
.env.*
!.env.example

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Documentation (not needed in runtime)
*.md
!README.md
docs/

# Test files (not needed in production)
tests/
**/*.test.ts
**/*.test.tsx
**/*.test.js
**/*.spec.ts
**/*.spec.tsx
**/*.spec.js
jest.config.js
vitest.config.ts

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml

# Docker files (not needed inside container)
Dockerfile
docker-compose*.yml
.dockerignore

# Temporary files
tmp/
temp/
*.tmp
