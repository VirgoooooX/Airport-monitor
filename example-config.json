    {
      "id": "airport_example_us",
      "name": "美国机场示例",
      "subscriptionUrl": "https://example.com/subscription/us",
      "nodes": [
        {
          "id": "node_us_1",
          "airportId": "airport_example_us",
          "name": "美国 01 - Los Angeles",
          "protocol": "trojan",
          "address": "us01.example.com",
          "port": 443,
          "config": {
            "password": "example-password",
            "sni": "us01.example.com"
          }
        },
        {
          "id": "node_us_2",
          "airportId": "airport_example_us",
          "name": "美国 02 - New York",
          "protocol": "shadowsocks",
          "address": "us02.example.com",
          "port": 8388,
          "config": {
            "method": "aes-256-gcm",
            "password": "example-password"
          }
        }
      ],
      "createdAt": "2024-01-01T00:00:00.000Z"
    }
  ],
  "checkInterval": 300,
  "checkTimeout": 30,
  "logLevel": "info",
  "storagePath": "./data/monitor.db",
  "checkConfig": {
    "tcpTimeout": 30,
    "httpTimeout": 30,
    "httpTestUrl": "https://www.google.com/generate_204",
    "latencyTimeout": 30,
    "bandwidthEnabled": false,
    "bandwidthTimeout": 60,
    "bandwidthTestSize": 1024
  },
  "subscriptionUpdate": {
    "updateInterval": 24,
    "enabled": true
  },
  "alertRules": [
    {
      "id": "rule_node_failure",
      "name": "节点失败率告警",
      "type": "node_failure_rate",
      "threshold": 0.3,
      "cooldownMinutes": 60,
      "enabled": true
    },
    {
      "id": "rule_airport_availability",
      "name": "机场可用性告警",
      "type": "airport_availability",
      "threshold": 0.5,
      "cooldownMinutes": 30,
      "enabled": true
    },
    {
      "id": "rule_consecutive_failures",
      "name": "连续失败告警",
      "type": "consecutive_failures",
      "threshold": 5,
      "cooldownMinutes": 15,
      "enabled": true
    }
  ]
}
