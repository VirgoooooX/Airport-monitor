{
  "name": "airport-node-monitor",
  "version": "1.0.8",
  "description": "Airport proxy node monitoring tool with availability tracking and reporting",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "airport-monitor": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "refresh-regions": "tsx scripts/refresh-region-data.ts",
    "clear-refresh-regions": "tsx scripts/clear-and-refresh-regions.ts",
    "release": "node scripts/release.mjs",
    "release:patch": "node scripts/release.mjs --bump patch",
    "release:minor": "node scripts/release.mjs --bump minor",
    "release:major": "node scripts/release.mjs --bump major"
  },
  "keywords": [
    "airport",
    "proxy",
    "monitor",
    "availability"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@types/sql.js": "^1.4.9",
    "@types/supertest": "^7.2.0",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.1",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "fast-check": "^3.15.0",
    "socks-proxy-agent": "^10.0.0",
    "sql.js": "^1.10.3",
    "yaml": "^2.8.3"
  }
}
